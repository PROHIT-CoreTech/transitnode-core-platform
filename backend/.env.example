# TransitNode ERP - Backend Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# ----------------- LOCALHOST CONFIGURATION -----------------
MONGO_URI_LOCALHOST=mongodb://localhost:27017/transitnode
JWT_SECRET_LOCALHOST=your_localhost_jwt_secret_here
MASTER_ADMIN_SECRET_KEY_LOCALHOST=your_localhost_master_admin_secret_here

# ----------------- DEVELOPMENT CONFIGURATION -----------------
MONGO_URI_DEVELOPMENT=mongodb+srv://<username>:<password>@cluster.mongodb.net/transitnode-dev
JWT_SECRET_DEVELOPMENT=your_development_jwt_secret_here
MASTER_ADMIN_SECRET_KEY_DEVELOPMENT=your_development_master_admin_secret_here

# ----------------- PRODUCTION CONFIGURATION -----------------
MONGO_URI_PRODUCTION=mongodb+srv://<username>:<password>@cluster.mongodb.net/transitnode-prod
JWT_SECRET_PRODUCTION=your_production_jwt_secret_here
MASTER_ADMIN_SECRET_KEY_PRODUCTION=your_production_master_admin_secret_here
